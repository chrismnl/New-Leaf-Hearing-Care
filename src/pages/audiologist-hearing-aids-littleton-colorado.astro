---
import Base from "../layouts/Base.astro";
import { getPublishedTeamMembers, replaceTeamSections } from "../utils/teamMembers";
import pageHtml from "../content-shells/static/audiologist-hearing-aids-littleton-colorado.html?raw";
export const cacheHint = 3600;

const teamMembers = await getPublishedTeamMembers();
const hydratedPageHtml = replaceTeamSections(pageHtml, teamMembers);
---
<Base title="New Leaf Hearing Care | Audiologists and Hearing Aids in Littleton, CO" description="New Leaf Hearing Care provides expert hearing care and hearing aids in Littleton, CO.">
  <Fragment set:html={hydratedPageHtml} />
</Base>
