---
import "../styles/local/global.css";
import "../styles/local/layout.css";
import "../styles/local/components.css";
import "../styles/local/sections.css";
import "../styles/local/pages/home.css";
import "../styles/local/pages/about.css";
import "../styles/local/pages/internal.css";
import "../styles/local/pages/contact.css";
import "../styles/local/pages/member.css";
import "../styles/local/pages/blog.css";
import "../styles/local/pages/Arvada.css";
import "../styles/local/pages/Littleton.css";
import Preloader from "../components/Preloader.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SiteScripts from "../components/SiteScripts.astro";

const { title = "New Leaf Hearing Care", description = "", canonical } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/webp" href="/assets/new-leaf-hearing-care-favicon.webp" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&family=Outfit:wght@500;600&family=Source+Serif+4:opsz,wght@8..60,600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Preloader />
    <Header />
    <slot />
    <Footer />
    <SiteScripts />
  </body>
</html>
